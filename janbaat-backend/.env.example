# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# ─── Database ────────────────────────────────────────────────────────────────
# Get from Supabase → Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# ─── Redis (Upstash) ─────────────────────────────────────────────────────────
REDIS_URL=redis://default:your-password@your-endpoint.upstash.io:6379

# ─── AI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key

# ─── Image Hosting ────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Push Notifications ──────────────────────────────────────────────────────
# Path to Firebase service account JSON file
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development        # development | production
APP_NAME=JanBaat
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100

# ─── Monitoring ──────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-key@sentry.io/your-project-id
